---
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";
import type { WidgetComponentConfig } from "@/types/config";

interface Props {
	class?: string;
	style?: string;
	widgetConfig?: WidgetComponentConfig;
}

const { class: className, style, widgetConfig } = Astro.props;
const showTitle = widgetConfig?.showTitle !== false;

const posts = await getSortedPosts();
const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))].sort() as string[];
---

<WidgetLayout
  name="订阅更新"
  showTitle={showTitle}
  id="subscribe"
  class={className}
  style={style}
>
  <subscribe-widget data-categories={JSON.stringify(categories)}>
    <p class="text-neutral-600 dark:text-neutral-300 text-sm leading-relaxed mb-3">
      输入邮箱，新文章发布时即时通知。
    </p>

    <div class="subscribe-form flex flex-col gap-2">
      <input
        type="email"
        placeholder="your@email.com"
        autocomplete="email"
        class="w-full px-3 py-2 rounded-lg text-sm
               bg-neutral-100/60 dark:bg-neutral-800/50
               text-neutral-900 dark:text-neutral-100
               border border-neutral-200 dark:border-neutral-700
               placeholder:text-neutral-400 dark:placeholder:text-neutral-500
               focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/40
               transition"
      />

      {categories.length > 0 && (
        <div>
          <p class="text-xs text-neutral-500 dark:text-neutral-400 mb-1.5">选择订阅分类：</p>
          <div class="category-chips flex flex-wrap gap-1.5">
            <button
              type="button"
              data-cat="全部"
              class="chip chip-selected rounded-full px-2.5 py-0.5 text-xs border transition-colors"
            >全部</button>
            {categories.map((cat) => (
              <button
                type="button"
                data-cat={cat}
                class="chip rounded-full px-2.5 py-0.5 text-xs border transition-colors"
              >{cat}</button>
            ))}
          </div>
        </div>
      )}

      <button
        type="button"
        class="subscribe-btn btn-regular rounded-lg h-9 px-4 text-sm font-medium active:scale-95 transition-transform w-full"
      >
        <span class="subscribe-btn-text">订阅</span>
        <Icon is:inline name="fa7-solid:paper-plane" class="subscribe-btn-icon ml-1.5 text-xs hidden" />
      </button>
    </div>

    <p class="subscribe-msg text-sm mt-2 hidden"></p>
  </subscribe-widget>
</WidgetLayout>

<style>
  .chip {
    background-color: rgb(245 245 245 / 0.6);
    border-color: rgb(229 229 229);
    color: rgb(82 82 82);
    cursor: pointer;
  }
  :global(.dark) .chip {
    background-color: rgb(38 38 38 / 0.5);
    border-color: rgb(64 64 64);
    color: rgb(163 163 163);
  }
  .chip-selected {
    background-color: var(--primary);
    border-color: transparent;
    color: white;
  }
  :global(.dark) .chip-selected {
    background-color: var(--primary);
    border-color: transparent;
    color: white;
  }
</style>

<script>
  class SubscribeWidget extends HTMLElement {
    private input: HTMLInputElement | null;
    private btn: HTMLButtonElement | null;
    private msg: HTMLElement | null;
    private form: HTMLElement | null;
    private selectedCategories: Set<string>;

    constructor() {
      super();
      this.input = this.querySelector("input[type=email]");
      this.btn = this.querySelector(".subscribe-btn");
      this.msg = this.querySelector(".subscribe-msg");
      this.form = this.querySelector(".subscribe-form");
      this.selectedCategories = new Set(["全部"]);

      if (localStorage.getItem("blog_subscribed") === "1") {
        this.showSuccess("您已订阅，感谢关注！");
        return;
      }

      this.initChips();
      this.btn?.addEventListener("click", () => this.handleSubmit());
      this.input?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") this.handleSubmit();
      });
    }

    private initChips() {
      const chips = this.querySelectorAll<HTMLButtonElement>(".chip");
      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const cat = chip.dataset.cat ?? "";
          if (cat === "全部") {
            this.selectedCategories = new Set(["全部"]);
          } else {
            this.selectedCategories.delete("全部");
            if (this.selectedCategories.has(cat)) {
              this.selectedCategories.delete(cat);
            } else {
              this.selectedCategories.add(cat);
            }
            if (this.selectedCategories.size === 0) {
              this.selectedCategories.add("全部");
            }
          }
          this.updateChips();
        });
      });
    }

    private updateChips() {
      const chips = this.querySelectorAll<HTMLButtonElement>(".chip");
      chips.forEach((chip) => {
        const cat = chip.dataset.cat ?? "";
        if (this.selectedCategories.has(cat)) {
          chip.classList.add("chip-selected");
        } else {
          chip.classList.remove("chip-selected");
        }
      });
    }

    private async handleSubmit() {
      const email = this.input?.value.trim() ?? "";
      if (!email) {
        this.showError("请输入邮箱地址");
        return;
      }

      this.setLoading(true);

      try {
        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, categories: [...this.selectedCategories] }),
        });
        const data = await res.json() as { success?: boolean; error?: string };

        if (res.ok && data.success) {
          localStorage.setItem("blog_subscribed", "1");
          this.showSuccess("订阅成功！请检查邮箱确认。");
        } else if (res.status === 409) {
          localStorage.setItem("blog_subscribed", "1");
          this.showSuccess("该邮箱已订阅，感谢关注！");
        } else {
          this.showError(data.error ?? "订阅失败，请稍后重试");
        }
      } catch {
        this.showError("网络错误，请稍后重试");
      } finally {
        this.setLoading(false);
      }
    }

    private setLoading(loading: boolean) {
      if (!this.btn) return;
      this.btn.disabled = loading;
      const text = this.btn.querySelector(".subscribe-btn-text");
      if (text) text.textContent = loading ? "提交中..." : "订阅";
    }

    private showSuccess(message: string) {
      this.form?.classList.add("hidden");
      if (this.msg) {
        this.msg.textContent = message;
        this.msg.className = "subscribe-msg text-sm mt-2 text-[var(--primary)]";
      }
    }

    private showError(message: string) {
      if (this.msg) {
        this.msg.textContent = message;
        this.msg.className = "subscribe-msg text-sm mt-2 text-red-500 dark:text-red-400";
      }
    }
  }

  if (!customElements.get("subscribe-widget")) {
    customElements.define("subscribe-widget", SubscribeWidget);
  }
</script>
